rules_version = '2';

// Rytm — per-user data isolation, plus basic structural validation.
// Every signed-in user can only read/write their own documents under
// users/{uid}/max_tracker/{doc}. Anonymous or cross-account access is denied.
// Deploy with: firebase deploy --only firestore:rules
//
// The validation below is deliberately shallow, not a full per-field
// schema: the `finance` doc in particular grows new top-level keys as
// features ship (see index.html's userDoc()/lsKey() comment, which already
// flagged that this file — not client code — is what actually has to
// enforce doc-name scoping). A strict field-by-field schema here would need
// updating on every new feature and risks silently breaking real users'
// sync the moment it drifts out of date with the client, which is worse
// than the gap it closes. Instead this guards against the concrete,
// low-maintenance risks: writing to an unexpected document name/path,
// wildly oversized documents, and malformed updatedAt/token fields that
// other logic (optimistic-concurrency conflict detection, the push sweep)
// relies on being the right type.
service cloud.firestore {
  match /databases/{database}/documents {
    // Known doc names: shifts, finance, debt, backup_v2, profiles_meta —
    // the first four also appear suffixed "@<profileId>" for non-default
    // profiles (profileId is always an app-generated `uid('profile')` id:
    // alphanumeric + underscore, see index.html); profiles_meta itself is
    // account-wide and never suffixed. A single path segment (not `**`) —
    // the only subcollection that exists under max_tracker is `finance`'s
    // own `transactions` (see the dedicated match block below, added for
    // MIGRATION_PLAN_transactions.md) — so this still closes off writing to
    // any *other* arbitrary nested path a client could otherwise reach
    // under their own uid.
    match /users/{uid}/max_tracker/{document} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // delete has no request.resource (it's null for a delete), so it must
      // be its own allow block rather than sharing the create/update one —
      // a single `allow write` that references request.resource.data denies
      // every delete, since that field access fails on a null resource.
      allow delete: if request.auth != null && request.auth.uid == uid
        && document.matches('^(shifts|finance|debt|backup_v2)(@[A-Za-z0-9_]+)?$|^profiles_meta$');
      allow create, update: if request.auth != null && request.auth.uid == uid
        && document.matches('^(shifts|finance|debt|backup_v2)(@[A-Za-z0-9_]+)?$|^profiles_meta$')
        // Generous headroom over the ~19 top-level keys the `finance` doc
        // currently has — catches a malformed/injected payload without
        // needing to be updated for every ordinary new feature field.
        && request.resource.data.keys().size() < 60
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is number)
        && (!('at' in request.resource.data) || request.resource.data.at is number);
    }

    function nullableString(d, field, maxLen) {
      return !(field in d) || d[field] == null || (d[field] is string && d[field].size() <= maxLen);
    }

    function validTxTags(d) {
      return !('tags' in d) || d.tags == null || (d.tags is list && d.tags.size() <= 20);
    }

    function validTransferFields(d) {
      return d.type != 'transfer' || (
        ('targetWallet' in d) && d.targetWallet is string && d.targetWallet.size() > 0 &&
        ('targetAmount' in d) && d.targetAmount is number && d.targetAmount > 0 && d.targetAmount < 1000000000 &&
        ('targetCurrency' in d) && d.targetCurrency is string && d.targetCurrency.matches('^[A-Z]{3}$')
      );
    }

    function validTransaction(d, txId) {
      return txId.matches('^[A-Za-z0-9_-]{1,80}$')
        && d.keys().size() < 24
        && d.type is string
        && d.type in ['income', 'expense', 'transfer']
        && d.amount is number
        && d.amount > 0
        && d.amount < 1000000000
        && d.date is string
        && d.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && nullableString(d, 'category', 120)
        && nullableString(d, 'subcategory', 120)
        && nullableString(d, 'comment', 500)
        && nullableString(d, 'wallet', 120)
        && nullableString(d, 'targetWallet', 120)
        && (!('currency' in d) || d.currency == null || (d.currency is string && d.currency.matches('^[A-Z]{3}$')))
        && (!('targetCurrency' in d) || d.targetCurrency == null || (d.targetCurrency is string && d.targetCurrency.matches('^[A-Z]{3}$')))
        && (!('createdAt' in d) || d.createdAt is number)
        && validTxTags(d)
        && validTransferFields(d);
    }

    // Per-transaction docs under a `finance`/`finance@<profileId>` doc (see
    // MIGRATION_PLAN_transactions.md and CLAUDE.md's Firebase data model
    // section — this replaced the old finance.data array). txId is the
    // app-generated transaction id, stringified client-side. Scoped to
    // financeDoc matching only `finance`(@profileId)? — not shifts/debt/
    // backup_v2/profiles_meta, none of which ever get a transactions
    // subcollection.
    match /users/{uid}/max_tracker/{financeDoc}/transactions/{txId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Same split as the parent doc's rules above: delete has no
      // request.resource, so it can't share an allow block with the field
      // validation below.
      allow delete: if request.auth != null && request.auth.uid == uid
        && financeDoc.matches('^finance(@[A-Za-z0-9_]+)?$')
        && txId.matches('^[A-Za-z0-9_-]{1,80}$');
      allow create, update: if request.auth != null && request.auth.uid == uid
        && financeDoc.matches('^finance(@[A-Za-z0-9_]+)?$')
        && validTransaction(request.resource.data, txId);
    }

    // FCM push token per account, written by the client when the user
    // enables push notifications. Read by the notificationSweep Cloud
    // Function via the Admin SDK (which bypasses these rules entirely) —
    // this rule only governs direct client access. The Admin SDK also
    // writes its own dedup fields (profileState, legacy sentDaily/
    // sentBudget/sentRecurring) onto this same doc, so validation here only
    // type/size-checks the client-writable fields when present rather than
    // allowlisting the doc's full key set, which would reject a client
    // token-refresh write after the sweep has already added its fields.
    match /push_tokens/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      // Same split as above: delete has no request.resource, so it can't
      // share an allow block with the field validation below.
      allow delete: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && (!('token' in request.resource.data) || (
          request.resource.data.token is string &&
          request.resource.data.token.size() > 0 &&
          request.resource.data.token.size() < 4096
        ))
        && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is number);
    }

    // Deny everything else by default (including the old shared
    // max_tracker/{doc} path used before per-user auth was added — its
    // one-time recovery window is closed, see git history for details).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
