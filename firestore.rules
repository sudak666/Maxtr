rules_version = '2';

// Xamss — per-user data isolation.
// Every signed-in user can only read/write their own documents under
// users/{uid}/max_tracker/{doc}. Anonymous or cross-account access is denied.
// Deploy with: firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/max_tracker/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // TEMPORARY: read-only access to the old shared collection so a
    // signed-in user can pull their pre-auth data into their own account
    // one time. Never allow writes here. Remove this block once the
    // one-time import is done (see index.html importLegacyData()).
    match /max_tracker/{document} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
