{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "js/tx-validation.js",
    "js/privacy-cache.js",
    "js/state.js",
    "js/receipt-ocr.js",
    "js/dashboard-widgets.js",
    "js/ui-widgets.js",
    "types/globals.d.ts"
  ],
  "exclude": ["js/vendor/**", "node_modules", "dist"]
}
